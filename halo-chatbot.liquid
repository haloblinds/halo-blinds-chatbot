{% comment %}
  Halo Blinds, on-page contact widget (no AI version).
  Paste this into a Shopify snippet named `halo-chatbot`.
  Render on product pages with: {% render 'halo-chatbot' %}

  How it works:
  - A launcher bubble sits bottom-right on the product page.
  - After 30 seconds a small teaser popup appears once per session.
  - Clicking either opens a panel with a simple contact form (name, email, question).
  - Submissions POST to the Vercel `/api/contact` endpoint.
  - The Vercel function emails help@haloblinds.com and logs to the dashboard.
{% endcomment %}

{%- assign api_url = 'https://halo-blinds-chatbot.vercel.app/api/contact' -%}
{%- assign brand_name = 'Halo' -%}
{%- assign brand_reply_time = 'Usually replies within 12 hours' -%}
{%- assign avatar_url = 'https://cdn.shopify.com/s/files/1/1046/8307/7966/files/Titel_12.png?v=1783170226' -%}
{%- assign teaser_delay_ms = 30000 -%}
{%- assign teaser_message = 'Ask us, we are happy to help!' -%}
{%- assign intro_text = 'Have a question about our blinds? Leave your details and we will reply within 12 hours.' -%}

<style>
  .halo-chat-launcher{position:fixed;right:20px;bottom:20px;width:60px;height:60px;border-radius:50%;background:#fff;border:none;cursor:pointer;box-shadow:0 6px 20px rgba(0,0,0,.18);display:flex;align-items:center;justify-content:center;z-index:9998;transition:transform .15s ease;font-family:inherit;padding:0;overflow:hidden}
  .halo-chat-launcher:hover{transform:scale(1.05)}
  .halo-chat-launcher::after{content:'';position:absolute;top:4px;right:4px;width:12px;height:12px;background:#4ade80;border:2px solid #fff;border-radius:50%;z-index:2}
  .halo-launcher-avatar{width:100%;height:100%;object-fit:cover;border-radius:50%}
  .halo-chat-launcher .halo-chat-close{position:absolute;inset:0;display:none;align-items:center;justify-content:center;background:#111;color:#fff}
  .halo-chat-launcher .halo-chat-close svg{width:22px;height:22px}
  .halo-chat-launcher.is-open .halo-launcher-avatar{display:none}
  .halo-chat-launcher.is-open::after{display:none}
  .halo-chat-launcher.is-open .halo-chat-close{display:flex}

  .halo-chat-panel{position:fixed;right:24px;bottom:96px;width:380px;max-width:calc(100vw - 48px);max-height:calc(100vh - 130px);background:#fff;border-radius:16px;box-shadow:0 12px 40px rgba(0,0,0,.16);display:none;flex-direction:column;overflow:hidden;z-index:9997;font-family:inherit;color:#111;animation:halo-panel-in .22s cubic-bezier(.22,1.1,.36,1)}
  .halo-chat-panel.is-open{display:flex}
  @keyframes halo-panel-in{from{opacity:0;transform:translateY(10px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}

  .halo-chat-header{padding:14px 16px;background:#111;color:#fff;display:flex;align-items:center;gap:12px;flex-shrink:0}
  .halo-avatar-wrap{position:relative;flex-shrink:0}
  .halo-header-avatar{width:40px;height:40px;border-radius:50%;object-fit:cover;background:#fff;display:block}
  .halo-avatar-wrap::after{content:'';position:absolute;bottom:-1px;right:-1px;width:12px;height:12px;background:#4ade80;border:2px solid #111;border-radius:50%}
  .halo-chat-header .halo-title{font-weight:600;font-size:15px;letter-spacing:-.01em;line-height:1.2}
  .halo-chat-header .halo-sub{font-size:12px;opacity:.7;margin-top:3px}

  .halo-chat-body{padding:18px;background:#fafafa;overflow-y:auto;flex:1}
  .halo-intro{font-size:14px;color:#333;line-height:1.5;margin-bottom:14px}
  .halo-form-field{margin-bottom:10px}
  .halo-form-field label{display:block;font-size:12px;color:#555;margin-bottom:4px;font-weight:500;letter-spacing:.01em}
  .halo-form-field input,
  .halo-form-field textarea{width:100%;border:1px solid #ddd;border-radius:10px;padding:10px 12px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box;background:#fff;transition:border-color .15s ease}
  .halo-form-field input:focus,
  .halo-form-field textarea:focus{border-color:#111}
  .halo-form-field input.halo-err,
  .halo-form-field textarea.halo-err{border-color:#e74c3c}
  .halo-form-field textarea{min-height:96px;resize:vertical;line-height:1.4}
  .halo-form-hint{font-size:11px;color:#888;margin-top:2px}

  .halo-submit{width:100%;background:#111;color:#fff;border:none;padding:12px 16px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:opacity .15s ease;margin-top:4px}
  .halo-submit:hover:not(:disabled){opacity:.9}
  .halo-submit:disabled{opacity:.5;cursor:not-allowed}

  .halo-privacy{font-size:11px;color:#888;text-align:center;margin-top:10px;line-height:1.4}

  .halo-success{text-align:center;padding:20px 8px}
  .halo-success-icon{width:56px;height:56px;background:#4ade80;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
  .halo-success-icon svg{width:28px;height:28px;color:#fff}
  .halo-success-title{font-size:16px;font-weight:600;color:#111;margin-bottom:6px}
  .halo-success-body{font-size:14px;color:#555;line-height:1.5}

  .halo-error{background:#fff5f5;border:1px solid #f5c2c2;color:#8b1a1a;font-size:13px;padding:10px 12px;border-radius:8px;margin-bottom:10px;display:none}
  .halo-error.is-visible{display:block}

  .halo-chat-teaser{position:fixed;right:24px;bottom:96px;background:#fff;border-radius:18px;padding:10px 12px;box-shadow:0 8px 24px rgba(0,0,0,.14);font-size:14px;color:#111;z-index:9996;max-width:280px;cursor:pointer;display:none;align-items:center;gap:10px;font-family:inherit;line-height:1.35;border:1px solid rgba(0,0,0,.05)}
  .halo-chat-teaser.is-visible{display:flex;animation:halo-teaser-in .35s cubic-bezier(.22,1,.36,1)}
  @keyframes halo-teaser-in{from{opacity:0;transform:translateY(8px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
  .halo-chat-teaser::after{content:'';position:absolute;right:22px;bottom:-6px;width:12px;height:12px;background:#fff;transform:rotate(45deg);border-right:1px solid rgba(0,0,0,.06);border-bottom:1px solid rgba(0,0,0,.06)}
  .halo-teaser-avatar{width:32px;height:32px;border-radius:50%;object-fit:cover;background:#f0ede6;flex-shrink:0}
  .halo-teaser-text{flex:1;padding-right:4px}
  .halo-chat-teaser-close{width:22px;height:22px;border:none;background:transparent;cursor:pointer;color:#999;font-size:18px;line-height:1;padding:0;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
  .halo-chat-teaser-close:hover{background:#f4f4f4;color:#333}

  @media (max-width:480px){
    .halo-chat-panel{right:12px;left:12px;width:auto;bottom:88px;max-height:calc(100vh - 110px)}
    .halo-chat-launcher{right:14px;bottom:14px}
    .halo-chat-teaser{right:14px;bottom:82px;max-width:calc(100vw - 28px)}
  }
</style>

<div class="halo-chat-teaser" id="halo-chat-teaser" role="button" tabindex="0" aria-label="{{ teaser_message }}, open contact form">
  <img class="halo-teaser-avatar" src="{{ avatar_url }}" alt="">
  <span class="halo-teaser-text">{{ teaser_message }}</span>
  <button class="halo-chat-teaser-close" id="halo-chat-teaser-close" aria-label="Dismiss">&times;</button>
</div>

<button class="halo-chat-launcher" id="halo-chat-launcher" aria-label="Open contact form">
  <img class="halo-launcher-avatar" src="{{ avatar_url }}" alt="{{ brand_name }}">
  <span class="halo-chat-close" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </span>
</button>

<div class="halo-chat-panel" id="halo-chat-panel" role="dialog" aria-label="{{ brand_name }} Contact form">
  <div class="halo-chat-header">
    <div class="halo-avatar-wrap">
      <img class="halo-header-avatar" src="{{ avatar_url }}" alt="{{ brand_name }}">
    </div>
    <div>
      <div class="halo-title">{{ brand_name }}</div>
      <div class="halo-sub">{{ brand_reply_time }}</div>
    </div>
  </div>

  <div class="halo-chat-body" id="halo-chat-body">
    <div class="halo-intro">{{ intro_text }}</div>
    <div class="halo-error" id="halo-error"></div>
    <form id="halo-contact-form" novalidate>
      <div class="halo-form-field">
        <label for="halo-input-name">Your name</label>
        <input type="text" id="halo-input-name" name="name" placeholder="First name" autocomplete="given-name" required>
      </div>
      <div class="halo-form-field">
        <label for="halo-input-email">Your email</label>
        <input type="email" id="halo-input-email" name="email" placeholder="you@example.com" autocomplete="email" required>
      </div>
      <div class="halo-form-field">
        <label for="halo-input-message">Your question</label>
        <textarea id="halo-input-message" name="message" placeholder="What would you like to know? For example: measuring, colours, delivery to my country..." required></textarea>
      </div>
      <button type="submit" class="halo-submit" id="halo-submit">Send question</button>
      <div class="halo-privacy">Goes straight to help@haloblinds.com. We reply within 12 hours.</div>
    </form>
  </div>
</div>

<script>
(function(){
  var API_URL = {{ api_url | json }};
  var launcher = document.getElementById('halo-chat-launcher');
  var panel = document.getElementById('halo-chat-panel');
  var form = document.getElementById('halo-contact-form');
  var nameInput = document.getElementById('halo-input-name');
  var emailInput = document.getElementById('halo-input-email');
  var messageInput = document.getElementById('halo-input-message');
  var submitBtn = document.getElementById('halo-submit');
  var body = document.getElementById('halo-chat-body');
  var errorEl = document.getElementById('halo-error');

  var productContext = {
    product_title: {{ product.title | default: '' | json }},
    product_price_display: {{ product.price | default: 0 | money | json }},
    product_url: {{ product.url | default: '' | json }},
    page_url: window.location.href
  };

  function togglePanel(){
    var open = panel.classList.toggle('is-open');
    launcher.classList.toggle('is-open', open);
    if (open){
      hideTeaser();
      setTimeout(function(){ nameInput.focus(); }, 80);
    }
  }
  launcher.addEventListener('click', togglePanel);

  // Teaser popup: shows after delay, once per session, only if panel not yet opened
  var teaser = document.getElementById('halo-chat-teaser');
  var teaserClose = document.getElementById('halo-chat-teaser-close');
  var TEASER_KEY = 'halo_teaser_dismissed';
  var panelOpenedOnce = false;

  function hideTeaser(){ teaser.classList.remove('is-visible'); }
  function dismissTeaser(){
    hideTeaser();
    try { sessionStorage.setItem(TEASER_KEY, '1'); } catch(e){}
  }
  teaser.addEventListener('click', function(e){
    if (e.target.closest('.halo-chat-teaser-close')) return;
    dismissTeaser();
    if (!panel.classList.contains('is-open')) togglePanel();
  });
  teaser.addEventListener('keydown', function(e){
    if (e.key === 'Enter' || e.key === ' '){
      e.preventDefault();
      dismissTeaser();
      if (!panel.classList.contains('is-open')) togglePanel();
    }
  });
  teaserClose.addEventListener('click', function(e){
    e.stopPropagation();
    dismissTeaser();
  });
  setTimeout(function(){
    if (panelOpenedOnce) return;
    try { if (sessionStorage.getItem(TEASER_KEY)) return; } catch(e){}
    teaser.classList.add('is-visible');
  }, {{ teaser_delay_ms }});

  // Subtle notification sound on submit success
  var _audioCtx = null;
  function playNotifSound(){
    try {
      _audioCtx = _audioCtx || new (window.AudioContext || window.webkitAudioContext)();
      if (_audioCtx.state === 'suspended') _audioCtx.resume();
      var now = _audioCtx.currentTime;
      var o = _audioCtx.createOscillator();
      var g = _audioCtx.createGain();
      o.connect(g); g.connect(_audioCtx.destination);
      o.type = 'sine';
      o.frequency.setValueAtTime(660, now);
      o.frequency.exponentialRampToValueAtTime(880, now + 0.08);
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.08, now + 0.015);
      g.gain.exponentialRampToValueAtTime(0.0001, now + 0.22);
      o.start(now); o.stop(now + 0.24);
    } catch(e){}
  }

  function isValidEmail(s){
    return typeof s === 'string' && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(s) && s.length <= 254;
  }
  function showError(msg){
    errorEl.textContent = msg;
    errorEl.classList.add('is-visible');
  }
  function hideError(){
    errorEl.classList.remove('is-visible');
    errorEl.textContent = '';
  }
  [nameInput, emailInput, messageInput].forEach(function(el){
    el.addEventListener('input', function(){ el.classList.remove('halo-err'); hideError(); });
  });

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    var name = (nameInput.value || '').trim();
    var email = (emailInput.value || '').trim();
    var message = (messageInput.value || '').trim();
    var hasErr = false;
    if (!name){ nameInput.classList.add('halo-err'); hasErr = true; }
    if (!isValidEmail(email)){ emailInput.classList.add('halo-err'); hasErr = true; }
    if (!message || message.length < 2){ messageInput.classList.add('halo-err'); hasErr = true; }
    if (hasErr){ showError('Please fill in your name, a valid email, and your question.'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    hideError();
    try {
      var res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, email: email, message: message, product_context: productContext })
      });
      var data = null;
      try { data = await res.json(); } catch(_){}
      if (!res.ok || !data || data.ok !== true){
        throw new Error((data && data.error) || ('http_' + res.status));
      }
      playNotifSound();
      body.innerHTML =
        '<div class="halo-success">' +
          '<div class="halo-success-icon">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
          '</div>' +
          '<div class="halo-success-title">Thanks, ' + escapeHtml(name) + '!</div>' +
          '<div class="halo-success-body">We got your question and will reply to <strong>' + escapeHtml(email) + '</strong> within 12 hours.</div>' +
        '</div>';
    } catch(err){
      console.error('[halo-contact]', err);
      showError('Something went wrong sending your message. Please email us directly at help@haloblinds.com.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send question';
    }
  });

  function escapeHtml(s){
    return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; });
  }
})();
</script>
