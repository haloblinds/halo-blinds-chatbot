# Copy to `.env.local` for `vercel dev`, or set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.

# --- Claude API ---
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Upstash Redis (free tier is plenty) ---
# Create a database at https://console.upstash.com and copy REST creds.
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=AX...

# --- Dashboard access ---
# Basic Auth password for /dashboard. Username is always "admin".
DASHBOARD_PASSWORD=change-me-to-something-strong

# --- CORS (optional but recommended for production) ---
# Comma-separated list of origins allowed to call /api/chat.
# Leave blank during local testing; set in prod to lock it down.
ALLOWED_ORIGINS=https://haloblinds.com,https://www.haloblinds.com,https://your-store.myshopify.com
